# Copy to .env (gitignored) and fill in. Never commit real keys.

# ── DeepSeek (implementation agents) ───────────────────────────────
DEEPSEEK_API_KEY=
# Model id — confirm which one you want. Common: deepseek-chat (flagship) | deepseek-reasoner
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_TEMPERATURE=0.15

# ── Anthropic (optional) ───────────────────────────────────────────
# Only for the in-app "Ask Claude → Field Notes" feature. The demo works WITHOUT it
# (falls back to the canned note baked into each animal). The browser reads the key from
# localStorage at runtime, not from this file — this is just a reminder/holder.
ANTHROPIC_API_KEY=
